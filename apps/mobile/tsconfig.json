{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "ignoreDeprecations": "6.0",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@pi-agents/contracts": [
        "../../packages/contracts/src"
      ]
    }
  },
  "include": [
    "app",
    "src"
  ],
  "exclude": [
    "src/**/__tests__/**",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "app/**/__tests__/**",
    "app/**/*.test.ts",
    "app/**/*.test.tsx"
  ]
}
