# fake is deterministic and suitable for UI/API development.
AGENT_RUNTIME=fake
# Use the local Pi CLI for real agent turns.
# AGENT_RUNTIME=pi
# PI_CWD=D:\Documents\ProjectsPet\chat-pi
# PI_BIN=pi.cmd
# PI_PROVIDER=
# PI_MODEL=
# PI_AGENT_DIR=D:\PiAgents\runtime

PORT=8787
# Standalone API only listens on loopback by default. Set to a specific
# Tailscale IP when a trusted tailnet device must reach it.
# API_HOST=100.116.45.50
MAX_BODY_BYTES=1048576
# Per-client limit for POST /api/projects/:projectId/packages/resolve.
PACKAGE_RESOLVE_RATE_LIMIT=10
PACKAGE_RESOLVE_RATE_WINDOW_SECONDS=60
# Enable only behind a trusted reverse proxy that overwrites X-Forwarded-For.
TRUST_PROXY=false
# Emits a structured warning when free space near DB_PATH falls below this value.
DISK_WARNING_FREE_BYTES=1073741824
DISK_CHECK_INTERVAL_SECONDS=300
# Required for NODE_ENV=production. Comma-separated origins; no paths.
# CORS_ORIGINS=https://chat.example.ts.net,http://100.116.45.50:8092
