# Required production browser origins. Use comma-separated origins, without paths.
CORS_ORIGINS=https://chat.example.ts.net

# Keep the API private by default. Use a Tailnet IP only when a device must reach it.
API_BIND_ADDRESS=127.0.0.1
API_PORT=8787
MAX_BODY_BYTES=1048576

# Host directory that contains repositories managed by the API.
# Windows example: PROJECTS_ROOT=D:/Documents/ProjectsPet
PROJECTS_ROOT=/srv/pi-agents/projects

# The VPS is the only Pi/Git execution environment. `fake` is an explicit
# smoke-test override; normal Tailnet deployment uses Pi.
AGENT_RUNTIME=pi
PI_BIN=/usr/local/bin/pi
PI_PROVIDER=
PI_MODEL=
# OpenCode Zen/OpenCode Go API key. Keep the real value in .env.docker only.
OPENCODE_API_KEY=
PI_SANDBOX_MODE=bwrap
PI_SANDBOX_BIN=/usr/bin/bwrap
# Comma-separated provider variables that Pi needs when credentials are not in /data/pi-agent.
PI_SANDBOX_ENV_ALLOWLIST=
PI_RUN_TIMEOUT_SECONDS=1200
# Docker's default seccomp profile rejects unshare(). Keep this as unconfined
# until a reviewed custom profile that permits bwrap is supplied.
PI_DOCKER_SECCOMP_PROFILE=unconfined
# Configure provider credentials in the protected Pi agent directory mounted
# at /data/pi-agent, or inject only the provider-specific secret required by Pi.
